# ─── Firebase Project Config ─────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ─── Google Maps ──────────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Google Sign-In OAuth Client IDs ─────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# ─── Emulator Host (DEV only) ─────────────────────────────────────────────────
# Environment switching is now automatic via React Native's __DEV__ global:
#   __DEV__ = true   → Expo / Metro dev build   → emulators connected
#   __DEV__ = false  → EAS production build     → live Firebase cloud
#
# NOTE: 'localhost' / '127.0.0.1' do NOT work on physical Android/iOS devices.
# You MUST set this to your workstation's local IPv4 address for device testing.
#
#   Find it:  Windows  → ipconfig | findstr "IPv4"
#             macOS    → ifconfig | grep "inet "
#
# If left blank the app falls back to:
#   • 10.0.2.2   for Android emulator  (host machine loopback alias)
#   • localhost  for iOS simulator / Expo web
#
EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=192.168.x.x
